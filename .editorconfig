# EditorConfig — https://editorconfig.org
# [M9] Enforces LF line endings project-wide to prevent CRLF/LF inconsistencies across OS

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.html]
indent_size = 4

[*.js]
indent_size = 4

[*.css]
indent_size = 4

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
